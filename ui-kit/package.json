{
  "name": "ui-kit",
  "type": "module",
  "version": "0.2.3",
  "description": "Starter template to get up and running quickly with Angular and Storybook",
  "author": "Chromatic <https://chromatic.com/>",
  "repository": {
    "type": "git",
    "url": "https://github.com/chromaui/intro-storybook-angular-template"
  },
  "bugs": {
    "url": "https://github.com/chromaui/intro-storybook-angular-template/issues"
  },
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --open",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "storybook": "ng run ui-kit:storybook",
    "build-storybook": "ng run ui-kit:build-storybook",
    "init-msw": "msw init src/",
    "lint": "npx eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write .",
    "ci:format": "prettier . --check",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.0.6",
    "@angular/common": "^19.0.6",
    "@angular/compiler": "^19.0.6",
    "@angular/core": "^19.0.6",
    "@angular/forms": "^19.0.6",
    "@angular/platform-browser": "^19.0.6",
    "@angular/platform-browser-dynamic": "^19.0.6",
    "@angular/router": "^19.0.6",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.7",
    "@angular/cli": "^19.0.7",
    "@angular/compiler-cli": "^19.0.6",
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@compodoc/compodoc": "^1.1.23",
    "@eslint/js": "^9.21.0",
    "@storybook/addon-essentials": "^8.3.3",
    "@storybook/addon-interactions": "^8.3.3",
    "@storybook/addon-links": "^8.3.3",
    "@storybook/angular": "^8.3.3",
    "@storybook/blocks": "^8.3.3",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^9.21.0",
    "eslint-plugin-storybook": "^0.11.3",
    "eslint-plugin-unicorn": "^57.0.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "msw": "^2.3.0",
    "msw-storybook-addon": "^2.0.3",
    "ng-packagr": "^19.0.0",
    "prettier": "^3.5.2",
    "sass": "^1.85.0",
    "sass-loader": "^16.0.5",
    "storybook": "^8.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0",
    "validate-branch-name": "^1.3.2"
  }
}
